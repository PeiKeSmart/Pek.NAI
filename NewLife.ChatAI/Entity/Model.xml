<?xml version="1.0" encoding="utf-8"?>
<EntityModel xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:schemaLocation="https://newlifex.com https://newlifex.com/Model202509.xsd" Document="https://newlifex.com/xcode/model" ModelVersion="2.0.2026.130" xmlns="https://newlifex.com/Model202509.xsd">
  <Option>
    <!--类名模板。其中{name}替换为Table.Name，如{name}Model/I{name}Dto等-->
    <ClassNameTemplate />
    <!--显示名模板。其中{displayName}替换为Table.DisplayName-->
    <DisplayNameTemplate />
    <!--基类。可能包含基类和接口，其中{name}替换为Table.Name-->
    <BaseClass>Entity</BaseClass>
    <!--命名空间-->
    <Namespace>NewLife.ChatAI.Entity</Namespace>
    <!--引用命名空间-->
    <ExtendNameSpace />
    <!--输出目录-->
    <Output>.\</Output>
    <!--是否使用中文文件名。默认false-->
    <ChineseFileName>True</ChineseFileName>
    <!--用于生成Copy函数的参数类型。例如{name}或I{name}-->
    <ModelNameForCopy />
    <!--带有索引器。实现IModel接口-->
    <HasIModel>False</HasIModel>
    <!--可为null上下文。生成String?等-->
    <Nullable>True</Nullable>
    <!--数据库连接名-->
    <ConnName>ChatAI</ConnName>
    <!--模型类模版。设置后生成模型类，用于接口数据传输，例如{name}Model-->
    <ModelClass />
    <!--模型类输出目录。默认当前目录的Models子目录-->
    <ModelsOutput>..\Models\</ModelsOutput>
    <!--模型接口模版。设置后生成模型接口，用于约束模型类和实体类，例如I{name}-->
    <ModelInterface />
    <!--模型接口输出目录。默认当前目录的Interfaces子目录-->
    <InterfacesOutput>.\Interfaces\</InterfacesOutput>
    <!--用户实体转为模型类的模型类。例如{name}或{name}DTO-->
    <ModelNameForToModel />
    <!--命名格式。Default/Upper/Lower/Underline-->
    <NameFormat>Default</NameFormat>
    <!--魔方区域显示名-->
    <DisplayName>AI对话</DisplayName>
    <!--魔方控制器输出目录-->
    <CubeOutput>../Areas/ChatAI/</CubeOutput>
  </Option>
  <Tables>
    <Table Name="Conversation" Description="会话。一次完整的多轮对话上下文" Output="消息对话">
      <Columns>
        <Column Name="Id" DataType="Int64" PrimaryKey="True" DataScale="time" Description="编号" />
        <Column Name="UserId" DataType="Int32" Description="用户。会话所属用户" />
        <Column Name="UserName" DataType="String" Description="用户名" />
        <Column Name="Title" DataType="String" Master="True" Length="200" Description="标题。会话标题，显示在侧边栏" />
        <Column Name="ModelId" DataType="Int32" Map="ModelConfig@Id@ModelName" Description="模型。当前使用的模型Id，引用ModelConfig.Id" />
        <Column Name="ModelName" DataType="String" Description="模型名称。冗余存储模型名称，方便历史数据检索" />
        <Column Name="SkillId" DataType="Int32" Map="Skill@Id@SkillName" Description="技能。当前会话使用的技能，引用Skill.Id" />
        <Column Name="SkillName" DataType="String" Description="技能名称。冗余存储技能名称，方便历史数据检索" />
        <Column Name="ThinkingMode" DataType="Int32" Description="思考模式。Auto=0自动, Think=1思考, Fast=2快速" Type="NewLife.AI.Models.ThinkingMode" />
        <Column Name="IsPinned" DataType="Boolean" Description="置顶。是否置顶显示" />
        <Column Name="MessageCount" DataType="Int32" Description="消息数" />
        <Column Name="LastMessageTime" DataType="DateTime" Description="最后消息时间。用于排序" />
        <Column Name="InputTokens" DataType="Int32" Description="输入Token数。会话累计消耗的输入Token数" />
        <Column Name="OutputTokens" DataType="Int32" Description="输出Token数。会话累计消耗的输出Token数" />
        <Column Name="TotalTokens" DataType="Int32" Description="总Token数。会话累计消耗的总Token数" />
        <Column Name="ElapsedMs" DataType="Int32" Description="耗时。毫秒" />
        <Column Name="Source" DataType="String" Description="来源。Web/Gateway/Channel等，标识对话入口" />
        <Column Name="TraceId" DataType="String" Description="链路。方便问题排查" Category="扩展" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
        <Column Name="Remark" DataType="String" Length="500" Description="备注" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="UserId,Id" />
        <Index Columns="UserId,IsPinned,Id" />
        <Index Columns="Source" />
      </Indexes>
    </Table>
    <Table Name="ChatMessage" Description="对话消息。会话中的单条发言，包括用户消息和AI回复" Output="消息对话">
      <Columns>
        <Column Name="Id" DataType="Int64" PrimaryKey="True" DataScale="time" Description="编号" />
        <Column Name="ConversationId" DataType="Int64" Description="会话。所属会话" />
        <Column Name="Role" DataType="String" Description="角色。User=用户, Assistant=AI助手" />
        <Column Name="Content" DataType="String" ItemType="markdown" ShowIn="Auto,-List,-Search" Length="-1" Description="内容。Markdown格式文本" />
        <Column Name="ThinkingContent" DataType="String" ItemType="markdown" ShowIn="Auto,-List,-Search" Length="-1" Description="思考内容。role=assistant时存AI推理过程；role=user时存本轮注入的系统上下文全文（含技能提示词与记忆注入，调试用）" />
        <Column Name="ThinkingMode" DataType="Int32" Description="思考模式。Auto=0自动, Think=1思考, Fast=2快速" Type="NewLife.AI.Models.ThinkingMode" />
        <Column Name="Attachments" DataType="String" ShowIn="Auto,-List,-Search" Length="500" Description="附件列表。存储魔方附件ID数组" />
        <Column Name="SkillNames" DataType="String" Length="200" Description="技能列表。本轮激活的技能名称，多个逗号分隔" />
        <Column Name="ToolNames" DataType="String" Length="500" Description="工具列表。role=user时记录本轮可用工具名（逗号分隔）；role=assistant时记录实际调用的工具名（逗号分隔）" />
        <Column Name="ToolCalls" DataType="String" ShowIn="Auto,-List,-Search" Length="-1" Description="工具调用。role=assistant时存实际调用链路ToolCallDto[]（含入参Arguments和执行结果Result）" />
        <Column Name="ModelName" DataType="String" Description="模型名称。实际使用的模型编码，方便回溯" />
        <Column Name="MaxTokens" DataType="Int32" Description="最大Token数。本次请求的最大生成Token数限制" />
        <Column Name="Temperature" DataType="Double" Description="温度。本次请求的采样温度参数" />
        <Column Name="FinishReason" DataType="String" Description="完成原因。stop=正常结束/length=截断/tool_calls=工具调用/error=异常" />
        <Column Name="InputTokens" DataType="Int32" Description="输入Token数" />
        <Column Name="OutputTokens" DataType="Int32" Description="输出Token数" />
        <Column Name="TotalTokens" DataType="Int32" Description="总Token数" />
        <Column Name="ElapsedMs" DataType="Int32" Description="耗时。毫秒" />
        <Column Name="TraceId" DataType="String" Description="链路。方便问题排查" Category="扩展" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="ConversationId,Id" />
      </Indexes>
    </Table>
    <Table Name="MessageFeedback" Description="消息反馈。用户对AI回复的点赞或点踩" Output="消息对话">
      <Columns>
        <Column Name="Id" DataType="Int32" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="ConversationId" DataType="Int64" Description="会话。被反馈的会话" />
        <Column Name="MessageId" DataType="Int64" Description="消息。被反馈的消息" />
        <Column Name="UserId" DataType="Int32" Map="XCode.Membership.User@ID@$@UserName" Description="用户。反馈用户" />
        <Column Name="FeedbackType" DataType="Int32" Description="反馈类型。Like=1点赞, Dislike=2点踩" Type="NewLife.AI.Models.FeedbackType" />
        <Column Name="Reason" DataType="String" Length="500" Description="原因。点踩原因" />
        <Column Name="AllowTraining" DataType="Boolean" Description="允许训练。是否允许用于模型学习训练" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="MessageId,UserId" Unique="True" />
        <Index Columns="UserId" />
        <Index Columns="ConversationId" />
      </Indexes>
    </Table>
    <Table Name="SharedConversation" Description="共享会话。通过链接分享的对话快照" Output="消息对话">
      <Columns>
        <Column Name="Id" DataType="Int64" PrimaryKey="True" DataScale="time" Description="编号" />
        <Column Name="ConversationId" DataType="Int64" Description="会话。被分享的会话" />
        <Column Name="ShareToken" DataType="String" Description="分享令牌。唯一标识，用于生成分享URL" />
        <Column Name="SnapshotTitle" DataType="String" Description="快照标题" />
        <Column Name="SnapshotMessageId" DataType="Int64" Description="快照消息。截止到的最后一条消息编号" />
        <Column Name="ExpireTime" DataType="DateTime" Description="过期时间。null表示永不过期" />
        <Column Name="CreateUser" DataType="String" Description="创建者" Category="扩展" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="ShareToken" Unique="True" />
        <Index Columns="ConversationId,Id" />
        <Index Columns="CreateUserID,Id" />
      </Indexes>
    </Table>
    <Table Name="UsageRecord" Description="用量记录。每次AI调用的Token消耗，支持按用户和AppKey双维度统计" InsertOnly="True" Output="消息对话">
      <Columns>
        <Column Name="Id" DataType="Int64" PrimaryKey="True" DataScale="time" Description="编号" />
        <Column Name="UserId" DataType="Int32" Map="XCode.Membership.User@ID@$@UserName" Description="用户" />
        <Column Name="AppKeyId" DataType="Int32" Description="应用密钥。通过API网关调用时关联的AppKey" />
        <Column Name="ConversationId" DataType="Int64" Description="会话" />
        <Column Name="MessageId" DataType="Int64" Description="消息。对应的AI回复消息" />
        <Column Name="ModelId" DataType="Int32" Description="模型。引用ModelConfig.Id" />
        <Column Name="ModelName" DataType="String" Description="模型名称。冗余存储模型名称，方便历史数据检索" />
        <Column Name="InputTokens" DataType="Int32" Description="输入Token数" />
        <Column Name="OutputTokens" DataType="Int32" Description="输出Token数" />
        <Column Name="TotalTokens" DataType="Int32" Description="总Token数" />
        <Column Name="CachedInputTokens" DataType="Int32" Description="缓存输入Token数" />
        <Column Name="ReasoningTokens" DataType="Int32" Description="推理Token数" />
        <Column Name="InputAudioTokens" DataType="Int32" Description="音频输入Token数" />
        <Column Name="InputTextTokens" DataType="Int32" Description="文本输入Token数" />
        <Column Name="OutputAudioTokens" DataType="Int32" Description="音频输出Token数" />
        <Column Name="OutputTextTokens" DataType="Int32" Description="文本输出Token数" />
        <Column Name="ElapsedMs" DataType="Int32" Description="耗时。毫秒" />
        <Column Name="Source" DataType="String" Description="请求来源。Chat=对话/Gateway=网关" />
        <Column Name="TraceId" DataType="String" Description="链路。方便问题排查" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="UserId,Id" />
        <Index Columns="AppKeyId,Id" />
        <Index Columns="ModelId,Id" />
        <Index Columns="ConversationId" />
      </Indexes>
    </Table>
    <Table Name="ProviderConfig" Description="提供商配置。AI服务商的连接信息，一个协议类型可以有多个实例" Output="系统配置">
      <Columns>
        <Column Name="Id" DataType="Int32" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="Code" DataType="String" Description="编码。提供商实例唯一标识，如my-openai" />
        <Column Name="Name" DataType="String" Master="True" Description="名称。显示名称，如公司OpenAI账号" />
        <Column Name="Provider" DataType="String" Description="实现类。IAiProvider实现类完整类名，如NewLife.AI.Providers.OpenAiProvider" />
        <Column Name="Endpoint" DataType="String" ItemType="url" Length="200" Description="接口地址。API地址" />
        <Column Name="ApiKey" DataType="String" ShowIn="Auto,-List,-Search" Length="200" Description="密钥。API访问密钥" />
        <Column Name="ApiProtocol" DataType="String" Description="API协议。ChatCompletions/ResponseApi/AnthropicMessages/Gemini" />
        <Column Name="ModelFilter" DataType="String" ShowIn="Auto,-List" Length="500" Description="模型过滤。逗号分隔的模型前缀或关键词，为空时发现全部。如：qwen-plus,qwen-max,deepseek" />
        <Column Name="ModelLimit" DataType="Int32" DefaultValue="10" Description="发现上限。单次模型发现的最大数量，0表示不限制，默认10" />
        <Column Name="RoleIds" DataType="String" Description="角色组。逗号分隔的角色ID列表，为空时不限制" />
        <Column Name="DepartmentIds" DataType="String" Description="部门组。逗号分隔的部门ID列表，为空时不限制" />
        <Column Name="Enable" DataType="Boolean" Description="启用" />
        <Column Name="Sort" DataType="Int32" Description="排序。越大越靠前" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
        <Column Name="Remark" DataType="String" Length="500" Description="备注" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="Code" Unique="True" />
        <Index Columns="Provider" />
      </Indexes>
    </Table>
    <Table Name="ModelConfig" Description="模型配置。后端接入的大语言模型，关联到具体的提供商实例" Output="系统配置">
      <Columns>
        <Column Name="Id" DataType="Int32" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="ProviderId" DataType="Int32" Map="ProviderConfig@Id@Name" Description="提供商。关联的提供商实例ID" />
        <Column Name="Code" DataType="String" Description="编码。模型唯一标识" />
        <Column Name="Name" DataType="String" Master="True" Description="名称。显示名称" />
        <Column Name="ContextLength" DataType="Int32" Description="上下文长度。模型支持的上下文窗口大小（令牌数）" />
        <Column Name="SupportThinking" DataType="Boolean" Description="思考。是否支持思考模式" />
        <Column Name="SupportFunctionCalling" DataType="Boolean" Description="函数调用。是否支持Function Calling" />
        <Column Name="SupportVision" DataType="Boolean" Description="视觉。是否支持图片输入" />
        <Column Name="SupportAudio" DataType="Boolean" Description="音频。是否支持音频输入输出" />
        <Column Name="SupportImageGeneration" DataType="Boolean" Description="图像。是否支持文生图" />
        <Column Name="SupportVideoGeneration" DataType="Boolean" Description="视频生成。是否支持文生视频" />
        <Column Name="SystemPrompt" DataType="String" ItemType="markdown" ShowIn="Auto,-List,-Search" Length="2000" Description="系统提示词。模型级System Prompt，发送给上游的系统消息" />
        <Column Name="RoleIds" DataType="String" Description="角色组。逗号分隔的角色ID列表，为空时不限制" />
        <Column Name="DepartmentIds" DataType="String" Description="部门组。逗号分隔的部门ID列表，为空时不限制" />
        <Column Name="ModelTime" DataType="DateTime" Description="模型时间。提供商侧的模型创建或最后更新时间" />
        <Column Name="Enable" DataType="Boolean" Description="启用" />
        <Column Name="Sort" DataType="Int32" Description="排序。越大越靠前" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
        <Column Name="Remark" DataType="String" Length="500" Description="备注" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="ProviderId,Code" Unique="True" />
      </Indexes>
    </Table>
    <Table Name="AppKey" Description="应用密钥。API网关访问凭证，用于外部系统调用模型服务" Output="系统配置">
      <Columns>
        <Column Name="Id" DataType="Int32" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="UserId" DataType="Int32" Map="XCode.Membership.User@ID@$@UserName" Description="用户。密钥所属用户" />
        <Column Name="Name" DataType="String" Master="True" Length="200" Description="名称。用户自定义标识，如业务系统A" />
        <Column Name="Secret" DataType="String" ShowIn="Auto,-List,-Search" Length="200" Description="密钥。sk-前缀的随机字符串，创建时仅展示一次" />
        <Column Name="Models" DataType="String" Length="200" Description="可用模型。逗号分隔的模型名称或编码，为空时不限制" />
        <Column Name="Enable" DataType="Boolean" Description="启用" />
        <Column Name="ExpireTime" DataType="DateTime" Description="过期时间。null表示永不过期" />
        <Column Name="LastCallTime" DataType="DateTime" Description="最后调用时间" />
        <Column Name="Calls" DataType="Int64" Description="调用次数。累计API请求数" />
        <Column Name="TotalTokens" DataType="Int64" Description="总Token数。累计消耗Token" />
        <Column Name="CreateUserID" DataType="Int32" Description="创建用户" Category="扩展" />
        <Column Name="CreateIP" DataType="String" Description="创建地址" Category="扩展" />
        <Column Name="CreateTime" DataType="DateTime" Description="创建时间" Category="扩展" />
        <Column Name="UpdateUserID" DataType="Int32" Description="更新用户" Category="扩展" />
        <Column Name="UpdateIP" DataType="String" Description="更新地址" Category="扩展" />
        <Column Name="UpdateTime" DataType="DateTime" Description="更新时间" Category="扩展" />
        <Column Name="Remark" DataType="String" Length="500" Description="备注" Category="扩展" />
      </Columns>
      <Indexes>
        <Index Columns="Secret" Unique="True" />
        <Index Columns="UserId" />
      </Indexes>
    </Table>
    <Table Name="UserSetting" Description="用户设置。用户的个性化配置" Output="系统配置">
      <Columns>
        <Column Name="Id" DataType="Int32" Identity="True" PrimaryKey="True" Description="编号" />
        <Column Name="UserId" DataType="Int32" Map="XCode.Membership.User@ID@$@UserName" Description="用户。设置所属用户" />
        <Column Name="Language" DataType="String" Description="语言。zh-CN/zh-TW/en" />
        <Column Name="Theme" DataType="String" Description="主题。light/dark/system" />
        <Column Name="FontSize" DataType="Int32" Description="字体大小。14~20，默认16" />
        <Column Name="SendShortcut" DataType="String" Description="发送快捷键。Enter或Ctrl+Enter" />
        <Column Name="DefaultModel" DataType="Int32" Description="默认模型。新会话的默认模型配置Id" />
        <Column Name="DefaultThinkingMode" DataType="Int32" Description="默认思考模式。Auto=0, Think=1, Fast=2" Type="NewLife.AI.Models.ThinkingMode" />
        <Column Name="ContextRounds" DataType="Int32" Description="上下文轮数。每次请求携带的历史对话轮数，默认10" />
        <Column Name="Nickname" DataType="String" Description="AI称呼。你希望AI怎么称呼你" />
        <Column Name="UserBackground" DataType="String" Length="500" Description="用户背景。你希望AI了解你的哪些信息，如职业、专长、偏好等" />
        <Column Name="ResponseStyle" DataType="Int32" Description="回应风格。AI回复的风格偏好。Balanced=0, Precise=1, Vivid=2, Creative=3" Type="NewLife.AI.Models.ResponseStyle" />
